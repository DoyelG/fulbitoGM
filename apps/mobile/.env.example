# Opcional. Si no está definida, en desarrollo la app infiere la IP del Metro (misma que tu Mac en la LAN)
# y usa el puerto 3000 para Next.
#
# Forzá la URL si usás Expo con túnel, otra red, o producción, ej.:
# EXPO_PUBLIC_WEB_URL=https://fulbito-gm.vercel.app
#
# El servidor Next debe estar en marcha: pnpm --filter @fulbito/web dev (escucha en 0.0.0.0:3000).
EXPO_PUBLIC_WEB_URL=http://fulbito-gm.vercel.app
# URL del backend Next.js (misma base de datos que la web). En desarrollo, usa la IP de tu máquina en la red local.
# Ejemplo: http://192.168.0.10:3000
EXPO_PUBLIC_API_URL=
