// Replaces Firebase Storage's default "test mode" rules, which expired
// on 2026-06-12 and caused 403 / storage/unauthorized errors on player
// photo uploads and reads. Publish with:
// `firebase deploy --only storage` (run from the repo root).
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Player photos: anyone may view; only signed-in users may upload.
    match /players/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
